    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body || {};\n\nconst required = ['idempotency_key', 'driver_id', 'trip_id', 'complaint_text'];\nconst missing = required.filter((f) => !body[f] || (typeof body[f] === 'string' && !body[f].trim()));\n\nif (missing.length > 0) {\n  return {\n    json: {\n      _validation: {\n        ok: false,\n        error: `Missing or empty required fields: ${missing.join(', ')}`,\n      },\n    },\n  };\n}\n\nif (typeof body.complaint_text !== 'string' || body.complaint_text.length > 5000) {\n  return {\n    json: {\n      _validation: {\n        ok: false,\n        error: 'complaint_text must be string ≤ 5000 chars',\n      },\n    },\n  };\n}\n\nreturn {\n  json: {\n    _validation: { ok: true },\n    payload: {\n      idempotency_key: String(body.idempotency_key),\n      driver_id: String(body.driver_id),\n      trip_id: String(body.trip_id),\n      complaint_text: body.complaint_text,\n      claimed_amount: typeof body.claimed_amount === 'number' ? body.claimed_amount : null,\n      submitted_at: body.submitted_at || new Date().toISOString(),\n      received_at: new Date().toISOString(),\n    },\n  },\n};\n"
      },
