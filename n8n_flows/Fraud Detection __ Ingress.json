      "name": "redis status check"
    },
    {
      "parameters": {
        "jsCode": "const LUA = `\nlocal idemKey = KEYS[1]\nlocal streamKey = KEYS[2]\nlocal dlqKey = KEYS[3]\nlocal requestId = ARGV[1]\nlocal payloadJson = ARGV[2]\nlocal enqueuedAt = ARGV[3]\nlocal maxLen = tonumber(ARGV[4])\n\n-- (1) Idempotency check\nlocal existing = redis.call('GET', idemKey)\nif existing then\n  return {0, existing, 'duplicate'}\nend\n\n-- (2) Overflow check BEFORE claiming idem key\nlocal streamLen = redis.call('XLEN', streamKey)\nif streamLen >= maxLen then\n  -- Push to DLQ instead. Don't claim idem so client can retry later.\n  redis.call('XADD', dlqKey, 'MAXLEN', '~', '10000', '*',\n    'request_id', requestId,\n    'payload', payloadJson,\n    'enqueued_at', enqueuedAt,\n    'reason', 'main_queue_overflow')\n  return {2, requestId, 'overflow'}\nend\n\n-- (3) Claim idem key atomically\nlocal ok = redis.call('SET', idemKey, requestId, 'NX', 'EX', 86400)\nif not ok then\n  -- race: someone else just set it (within microseconds)\n  local now = redis.call('GET', idemKey)\n  return {0, now, 'duplicate'}\nend\n\n-- (4) Enqueue\nredis.call('XADD', streamKey, '*',\n  'request_id', requestId,\n  'payload', payloadJson,\n  'enqueued_at', enqueuedAt)\n\nreturn {1, requestId, 'accepted'}\n`;\n\nconst item = $input.first();\nconst payload = item.json.payload;\nconst requestId = `req_${item.json.request_uuid}`;\nconst enqueuedAt = new Date().toISOString();\nconst MAX_QUEUE_LEN = 100000;\n\nconst idemKey = `fraud:idem:${payload.idempotency_key}`;\nconst streamKey = 'fraud:stream:webhooks';\nconst dlqKey = 'fraud:stream:webhooks:dlq';\n\nconst Redis = require('ioredis');\nconst redis = new Redis({\n  host: 'redis',\n  port: 6379,\n  connectTimeout: 5000,\n  commandTimeout: 5000,\n  maxRetriesPerRequest: 1,\n});\n\ntry {\n  const [statusCode, returnedId, statusName] = await redis.eval(\n    LUA,\n    3, \n    idemKey,\n    streamKey,\n    dlqKey,\n    requestId,\n    JSON.stringify(payload),\n    enqueuedAt,\n    String(MAX_QUEUE_LEN),\n  );\n\n  await redis.quit();\n\n  return [\n    {\n      json: {\n        _redis: { ok: true },\n        status: statusName,\n        is_duplicate: statusCode === 0,\n        is_overflow: statusCode === 2,\n        request_id: returnedId,\n        payload,\n      },\n    },\n  ];\n} catch (err) {\n  try { await redis.quit(); } catch {}\n  return [\n    {\n      json: {\n        _redis: { ok: false, error: String(err.message || err) },\n        payload,\n      },\n    },\n  ];\n}"
      },
